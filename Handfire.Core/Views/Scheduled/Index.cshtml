@using Handfire.Core;
@using Handfire.Core.Models;
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@model PagedList<JobModel>

<!DOCTYPE html>
<html lang="en">
<head>
    <title>Completed</title>
</head>
<body>
    <!-- Navigation -->
    @await Html.PartialAsync("../Shared/_Nav")

    <h3>Scheduled</h3>

    @await Html.PartialAsync("../Shared/_JobTable", Model)

    <div style="margin: 1rem;">
        @for (var i = 0; i < Model.PageCount; i++)
        {
            <a class="pagination-btn" asp-controller="Jobs" asp-action="Created" asp-route-page="@i" asp-route-pageSize="20">@(i + 1)</a>
        }
    </div>
</body>

<style>
    .pagination-btn {
        background-color: whitesmoke;
        border: 2px solid whitesmoke;
        padding: 0.2rem;
        border-radius: 2px;
        cursor: pointer;
        text-decoration: none;
        color: black;
    }

        .pagination-btn:hover {
            border: 2px solid lightgray;
        }
</style>

<script type="text/javascript">
    setTimeout(function () {
        window.location.reload();
    }, 1000)
</script>
</html>
<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageId>Moberg.Jobly.Provider.PostgreSql</PackageId>
		<Description>PostgreSQL provider for Moberg.Jobly — notification transport (LISTEN/NOTIFY), row-lock SQL, distributed lock, and exception classification.</Description>
	</PropertyGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="Jobly.Tests" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="DistributedLock.Postgres" Version="1.3.0" />
		<PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.1" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Jobly.Core\Jobly.Core.csproj" />
		<ProjectReference Include="..\..\Jobly.Worker\Jobly.Worker.csproj" />
	</ItemGroup>

</Project>

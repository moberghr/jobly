<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageId>Moberg.Warp.Provider.PostgreSql</PackageId>
		<Description>PostgreSQL provider for Moberg.Warp — notification transport (LISTEN/NOTIFY), row-lock SQL, distributed lock, and exception classification.</Description>
	</PropertyGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="Warp.Tests" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="DistributedLock.Postgres" Version="1.3.0" />
		<PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.1" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Warp.Core\Warp.Core.csproj" />
		<ProjectReference Include="..\..\Warp.Worker\Warp.Worker.csproj" />
	</ItemGroup>

</Project>
